{
  "name": "intellilaw-desktop",
  "version": "1.0.0",
  "description": "IntelliLaw — Offline AI-Native Legal Operating System",
  "author": "IGLA Centre for AI & Digital Transformation",
  "private": true,
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "terser": "^5.46.0",
    "vite": "^5.4.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.intellilaw.desktop",
    "productName": "IntelliLaw",
    "copyright": "Copyright 2025 IGLA CAIDT",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/backend-dist/",
        "to": "backend/",
        "filter": ["IntelliLaw-backend.exe", "IntelliLaw-backend"]
      }
    ],
    "extraFiles": [
      { "from": "assets/LAN_ACCESS.txt", "to": "LAN_ACCESS.txt" },
      { "from": "assets/download_model.bat", "to": "download_model.bat" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IntelliLaw",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": "assets/LICENSE.txt",
      "deleteAppDataOnUninstall": false
    }
  }
}
